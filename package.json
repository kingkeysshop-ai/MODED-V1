{
  "name": "medusa-next",
  "version": "1.0.3",
  "private": true,
  "author": "Kasper Fabricius Kristensen <kasper@medusajs.com> & Victor Gerbrands <victor@medusajs.com> (https://www.medusajs.com)",
  "description": "Next.js Starter to be used with Medusa V1",
  "keywords": [
    "medusa-storefront"
  ],
  "scripts": {
    "check:env": "node check-env-variables.js",
    "dev": "next dev --turbopack -p 8000",
