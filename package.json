    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-instantsearch-dom": "^6.12.3",
    "autoprefixer": "^10.4.2",
    "babel-loader": "^8.2.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.3.6",
    "postcss": "^8.4.8",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0"
  },
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.0.0"
