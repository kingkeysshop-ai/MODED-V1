    "start": "npm run check:env && next start -p ${PORT:-8000}",
    "lint": "next lint",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@internationalized/date": "^3.5.4",
    "@medusajs/icons": "~1.2.2",
    "@medusajs/medusa-js": "~1.3.10",
    "@medusajs/ui": "~3.0.1",
    "@radix-ui/react-accordion": "^1.2.1",
    "@stripe/react-stripe-js": "^3.1.0",
    "@stripe/stripe-js": "^4.9.0",
    "ansi-colors": "^4.1.3",
    "framer-motion": "^11.3.0",
    "lodash": "^4.17.21",
    "next": "^15.3.6",
    "pg": "^8.11.3",
    "qs": "^6.12.1",
    "react": "19.0.0",
    "react-country-flag": "^3.1.0",
    "react-dom": "19.0.0",
    "server-only": "^0.0.1",
    "tailwindcss-radix": "^2.8.0"
